{
  "name": "zod-toolkit",
  "version": "0.0.2",
  "description": "Stop rewriting validators. Ship production-ready schemas with Zod Toolkit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prettier": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wesleydmscn/zod-toolkit.git"
  },
  "keywords": [
    "schema-validation",
    "type-inference",
    "runtime-validation",
    "zod",
    "typescript"
  ],
  "author": "Wesley Damasceno",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wesleydmscn/zod-toolkit/issues"
  },
  "homepage": "https://github.com/wesleydmscn/zod-toolkit#readme",
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.4",
    "prettier": "3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
